// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- STAFF & PROFILE ---
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      Role     @default(FIELD_WORKER)
  phone     String?
  avatar    String?
  status    Status   @default(OFF_DUTY)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  managedAreas         Area[]
  assignedTickets      Ticket[]
  equipmentAssigned    Equipment[]
  inventoryTransactions InventoryTransaction[]
  equipmentLogs        EquipmentLog[]
  measurementsDone     MeasurementRecord[]
  schedules            Schedule[]
  leaveRequests        LeaveRequest[]
  shiftSwapsRequested  ShiftSwapRequest[] @relation("SwapRequester")
  shiftSwapsReceived   ShiftSwapRequest[] @relation("SwapRecipient")
  certifications       Certification[]
}

// --- STAFF SCHEDULING & MANAGEMENT ---
model Schedule {
  id        String   @id @default(uuid())
  userId    String
  dayOfWeek Int      // 0 = Sunday, 1 = Monday, etc.
  startTime String   // e.g., "08:00"
  endTime   String   // e.g., "16:00"
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id        String   @id @default(uuid())
  userId    String
  startDate DateTime
  endDate   DateTime
  reason    String
  status    RequestStatus @default(PENDING)
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShiftSwapRequest {
  id             String   @id @default(uuid())
  requesterId    String
  recipientId    String
  dateToSwap     DateTime
  reason         String?
  status         RequestStatus @default(PENDING)
  createdAt      DateTime @default(now())

  requester      User     @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient      User     @relation("SwapRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Certification {
  id             String   @id @default(uuid())
  userId         String
  name           String
  issueDate      DateTime
  expirationDate DateTime?
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  SUPERVISOR
  FIELD_WORKER
}

enum Status {
  ON_DUTY
  OFF_DUTY
}

// --- AREAS & SUB-AREAS ---
model Area {
  id            String   @id @default(uuid())
  name          String
  image         String?
  responsibleId String?
  responsible   User?    @relation(fields: [responsibleId], references: [id])
  createdAt     DateTime @default(now())

  subAreas      SubArea[]
  tickets       Ticket[]
}

model SubArea {
  id        String   @id @default(uuid())
  name      String
  areaId    String
  area      Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  tickets   Ticket[]
}

// --- TASKS (TICKETS) ---
model Ticket {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      TicketStatus @default(PENDING)
  priority    Priority @default(MEDIUM)
  areaId      String
  subAreaId   String?
  assigneeId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  area        Area     @relation(fields: [areaId], references: [id])
  subArea     SubArea? @relation(fields: [subAreaId], references: [id])
  assignee    User?    @relation(fields: [assigneeId], references: [id])
  inventoryTransactions InventoryTransaction[]
  equipments          Equipment[]
  equipmentLogs       EquipmentLog[]
}

enum TicketStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// --- INVENTORY ---
model InventoryItem {
  id           String   @id @default(uuid())
  name         String
  category     String
  currentStock Float    @default(0)
  minStock     Float    @default(0)
  unit         String
  lastUpdated  DateTime @default(now()) @updatedAt

  transactions InventoryTransaction[]
}

model InventoryTransaction {
  id        String   @id @default(uuid())
  itemId    String
  userId    String
  ticketId  String?
  type      TransactionType
  quantity  Float
  date      DateTime @default(now())

  item      InventoryItem @relation(fields: [itemId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
  ticket    Ticket?       @relation(fields: [ticketId], references: [id])
}

enum TransactionType {
  IN
  OUT
}

// --- EQUIPMENT ---
model Equipment {
  id          String   @id @default(uuid())
  name        String
  status      EquipmentStatus @default(AVAILABLE)
  assigneeId  String?
  ticketId    String?
  createdAt   DateTime @default(now())

  assignee    User?    @relation(fields: [assigneeId], references: [id])
  ticket      Ticket?  @relation(fields: [ticketId], references: [id])
  logs        EquipmentLog[]
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  RESERVED
  MAINTENANCE
}

model EquipmentLog {
  id          String   @id @default(uuid())
  equipmentId String
  userId      String
  ticketId    String?
  action      EquipmentAction
  date        DateTime @default(now())

  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  ticket      Ticket?   @relation(fields: [ticketId], references: [id])
}

enum EquipmentAction {
  CHECK_OUT
  RETURN
}

// --- MEASUREMENTS (DYNAMIC MODULES - ISSUE #9) ---
model MeasurementModule {
  id          String   @id @default(uuid())
  name        String   // Ej: "Piscinas", "Cámaras Frigoríficas"
  description String?
  createdAt   DateTime @default(now())

  parameters  MeasurementParameter[]
  records     MeasurementRecord[]
}

model MeasurementParameter {
  id          String   @id @default(uuid())
  moduleId    String
  name        String   // Ej: "Temperatura", "Nivel de Cloro"
  type        ParamType @default(NUMBER)
  minHealthy  Float?   // Límite inferior sano
  maxHealthy  Float?   // Límite superior sano
  unit        String?  // Ej: "°C", "ppm"

  module      MeasurementModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  values      MeasurementValue[]
}

enum ParamType {
  NUMBER
  BOOLEAN
  TEXT
}

model MeasurementRecord {
  id          String   @id @default(uuid())
  moduleId    String
  userId      String
  date        DateTime @default(now())

  module      MeasurementModule @relation(fields: [moduleId], references: [id])
  user        User              @relation(fields: [userId], references: [id])
  values      MeasurementValue[]
}

model MeasurementValue {
  id           String   @id @default(uuid())
  recordId     String
  parameterId  String
  value        String   // Guardamos como string y parseamos según el ParamType
  isHealthy    Boolean  // Calculado al momento de insertar basado en minHealthy/maxHealthy

  record       MeasurementRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  parameter    MeasurementParameter @relation(fields: [parameterId], references: [id])
}
